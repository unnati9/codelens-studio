# Public browser credentials from Supabase Project Settings > API.
# The anon key is intentionally public and protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use the publishable key shown by current Supabase projects. The legacy
# NEXT_PUBLIC_SUPABASE_ANON_KEY name is also supported.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional. Defaults to board-media when omitted.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=board-media

# Optional server-only token for higher public GitHub API rate limits.
# Do not prefix this value with NEXT_PUBLIC_.
GITHUB_TOKEN=

# GitHub App user authorization. All values are server-only; never add a
# NEXT_PUBLIC_ prefix. The callback URL must be registered in the GitHub App.
APP_URL=http://localhost:3000
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=
# Generate at least 32 random bytes, for example: openssl rand -base64 32
GITHUB_SESSION_SECRET=
# Optional. When set, it must equal ${APP_URL}/api/github/auth/callback exactly.
GITHUB_APP_CALLBACK_URL=

# Optional connected-GitHub pagination safety limits.
GITHUB_INSTALLATION_LIST_LIMIT=100
GITHUB_REPOSITORY_LIST_LIMIT=1000
GITHUB_OPEN_PR_LIST_LIMIT=300

# Optional server-side safety limits. Defaults: 300 fetched files, 20 imported files.
GITHUB_PR_MAX_FILES=300
GITHUB_IMPORT_LIMIT=20

# Server-only Vercel personal or team access token used to query deployment metadata.
# The token must be able to read the configured Vercel project. Never add NEXT_PUBLIC_.
VERCEL_TOKEN=

# Optional affected-route analyzer bounds. Values above the built-in hard caps are clamped.
AFFECTED_ROUTE_MAX_DEPTH=8
AFFECTED_ROUTE_MAX_FILES=300
AFFECTED_ROUTE_MAX_FILE_SIZE_BYTES=200000
AFFECTED_ROUTE_TIMEOUT_MS=8000
